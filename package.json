{
  "name": "doordash-cli",
  "version": "0.4.0",
  "description": "Cart-safe DoorDash CLI with direct API support for browse, read-only existing-order, and cart workflows.",
  "type": "module",
  "main": "dist/lib.js",
  "bin": {
    "dd-cli": "dist/bin.js",
    "doordash-cli": "dist/bin.js"
  },
  "man": [
    "man/dd-cli.1",
    "man/doordash-cli.1"
  ],
  "files": [
    "dist",
    "man",
    "docs/install.md",
    "docs/examples.md",
    "scripts/install-manpage.sh",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "cli": "node dist/bin.js",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "validate": "npm run typecheck && npm test",
    "install:man": "bash scripts/install-manpage.sh",
    "install:browser": "npm run cli -- install-browser",
    "smoke:pack": "node scripts/smoke-pack-install.mjs"
  },
  "keywords": [
    "doordash",
    "cli",
    "playwright",
    "cart-safe"
  ],
  "author": "doordash-cli contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LatencyTDH/doordash-cli.git"
  },
  "bugs": {
    "url": "https://github.com/LatencyTDH/doordash-cli/issues"
  },
  "homepage": "https://github.com/LatencyTDH/doordash-cli#readme",
  "dependencies": {
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^24.3.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "release-it": "^19.2.4",
    "typescript": "^5.9.2"
  }
}
