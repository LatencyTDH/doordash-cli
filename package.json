{
  "name": "doordash-cli",
  "version": "0.1.0",
  "description": "Cart-safe DoorDash CLI with direct API support for browse, read-only existing-order, and cart workflows.",
  "type": "module",
  "private": true,
  "main": "dist/lib.js",
  "bin": {
    "dd-cli": "dist/bin.js",
    "doordash-cli": "dist/bin.js"
  },
  "man": [
    "man/dd-cli.1",
    "man/doordash-cli.1"
  ],
  "files": [
    "dist",
    "man",
    "scripts/install-manpage.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "validate": "npm run typecheck && npm test",
    "install:man": "bash scripts/install-manpage.sh"
  },
  "keywords": [
    "doordash",
    "cli",
    "playwright",
    "cart-safe"
  ],
  "author": "doordash-cli contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seans-openclawbot/doordash-cli.git"
  },
  "bugs": {
    "url": "https://github.com/seans-openclawbot/doordash-cli/issues"
  },
  "homepage": "https://github.com/seans-openclawbot/doordash-cli#readme",
  "dependencies": {
    "@striderlabs/mcp-doordash": "^0.1.2",
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
